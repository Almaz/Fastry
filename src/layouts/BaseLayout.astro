---
import '@/styles/global.css';
import fontsCss from '@/styles/fonts/fonts.css?url';
import interLatinFont from '@/assets/fonts/inter-latin-wght-normal.woff2?url';
import interCyrillicFont from '@/assets/fonts/inter-cyrillic-wght-normal.woff2?url';
import SEO from '@/components/seo/SEO.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import Analytics from '@/components/layout/Analytics.astro';
import ConsentBanner from '@/components/ui/overlay/ConsentBanner';
import CursorTrail from '@/components/effects/CursorTrail.astro';
import { createWebsiteSchema, createOrganizationSchema, createPersonSchema, createProfessionalServiceSchema } from '@/lib/schema';
import type { Thing, WithContext } from 'schema-dts';
import siteConfig from '@/config/site.config';
import { getLocaleFromPath } from '@/i18n';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  article?: {
    publishedTime?: Date;
    modifiedTime?: Date;
    authors?: string[];
    tags?: string[];
  };
  noindex?: boolean;
  nofollow?: boolean;
  includeOrgSchema?: boolean;
  includePersonSchema?: boolean;
  includeProfessionalServiceSchema?: boolean;
  extraSchemas?: WithContext<Thing>[];
  eagerReveal?: boolean;
  /** When true, the scroll-progress bar sits at the very top of the viewport
   *  (above the header). When false (default), it sits below the header
   *  (top-[64px]), matching the bar-shaped header layout. */
  scrollProgressAtTop?: boolean;
}

const {
  title,
  description,
  image,
  imageAlt,
  article,
  noindex = false,
  nofollow = false,
  includeOrgSchema = false,
  includePersonSchema = false,
  includeProfessionalServiceSchema = false,
  extraSchemas = [],
  eagerReveal = false,
  scrollProgressAtTop = false,
} = Astro.props;

// Build JSON-LD schemas
const schemas: WithContext<Thing>[] = [createWebsiteSchema()];
if (includeOrgSchema) {
  schemas.push(createOrganizationSchema());
}
if (includePersonSchema) {
  schemas.push(createPersonSchema());
}
if (includeProfessionalServiceSchema) {
  schemas.push(createProfessionalServiceSchema());
}
schemas.push(...extraSchemas);

const locale = getLocaleFromPath(Astro.url.pathname);
---

<!doctype html>
<html lang={locale} data-pagefind-filter={`lang:${locale}`} class="scroll-smooth dark" data-theme="orange" data-theme-mode="system">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Async font stylesheet: loaded with media="print" trick so it
         does not block the critical rendering path. The @font-face
         rules inside use font-display:optional for Inter (LCP) and
         swap for secondary fonts. Metric-adjusted fallbacks are in
         global.css to prevent CLS.
         Font binaries are imported from src/assets/fonts so Vite emits
         hashed, cache-friendly URLs instead of stable /fonts/* paths. -->
    <link rel="preload" href={interLatinFont} as="font" type="font/woff2" crossorigin media="print" onload="this.media='all'" />
    <link rel="preload" href={interCyrillicFont} as="font" type="font/woff2" crossorigin media="print" onload="this.media='all'" />
    <link rel="stylesheet" href={fontsCss} media="print" onload="this.setAttribute('media','all')" />
    <noscript><link rel="stylesheet" href={fontsCss} /></noscript>

    {siteConfig.articleFeatures?.comments?.enabled && (
      <link rel="preconnect" href="https://giscus.app" crossorigin />
    )}

    <!-- Favicon. Static SVG fallback in public/favicon.svg; the inline script
         below replaces it with a data URI using the active --brand-500 colour
         so the favicon always matches the current theme. PNG/ICO fallbacks are
         provided for search-engine crawlers, Safari and legacy browsers. -->
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}${siteConfig.branding.favicon.svg.replace(/^\//, '')}`} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <!-- manifest loaded via SW, does not block critical path -->
    <!-- theme-color static meta; JS updates content before paint -->
    <meta name="theme-color" content="#ee4000" id="theme-color-meta" />
    <!-- ================================================================
         UNIFIED BOOTSTRAP — single script with all application logic
         ================================================================
         1. Critical (sync, before first paint, zero forced layout):
            - theme-color meta (only content update, no DOM creation)
            - data-theme and data-theme-mode on <html>
            - .dark class for dark mode
         2. After window.load (off critical path):
            - Favicon (data URI replacement)
            - Scroll-progress bar (all scrollHeight via ResizeObserver only)
            - Back-to-top (same approach — zero layout reads on scroll)
            - Scroll reveal (IntersectionObserver, no getBoundingClientRect)
            - Service Worker registration
    -->
    <script is:inline>
      (function () {
        'use strict';
        /* ------------------------------------------------------------------ */
        /*  CONSTANTS                                                         */
        /* ------------------------------------------------------------------ */
        var TC = { orange:'#ee4000', amber:'#da8100', lime:'#4fa700', emerald:'#00ac55', teal:'#00aca5', cyan:'#00a9bb', sky:'#009ee5', blue:'#0083ff', indigo:'#316fff', violet:'#6a65ff', purple:'#934aff', magenta:'#cb00c6', green:'#00ab45' };
        var FC = { orange:'#993a00', amber:'#995a00', lime:'#3d7a00', emerald:'#007a3d', teal:'#007a75', cyan:'#007a8a', sky:'#00709a', blue:'#005fcc', indigo:'#2a4fcc', violet:'#4a45cc', purple:'#6a2fcc', magenta:'#9a0090', green:'#007a30' };
        var THEMES = ['orange','amber','lime','emerald','teal','cyan','sky','blue','indigo','violet','purple','magenta','green'];
        var SVG_PREFIX = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 14.32 14.32"><path fill="#fff" d="M14.32 7.15a7.16 7.16 0 0 1-7.16 7.16A7.16 7.16 0 0 1 0 7.15 7.16 7.16 0 0 1 7.16-.01a7.16 7.16 0 0 1 7.16 7.16"/><path fill="';
        var SVG_SUFFIX = '" d="M.26 5.23a7.5 7.5 0 0 0-.1 3.4c2.5.34 4.46.27 2.4 1.45-2.23 1.3 2.1 2.95 5.26 2.95 1.56 0 2.98-.61 4.03-1.6h-.63c-1.53 0-4.24.37-4.21-1.97.02-2.1 2.51-1.98 4.1-1.97 0-.34-.37-.93-1.43-.93H5.87v4.87H4.12V6.55h-.96V5.21h.96c0-.98.34-2.45 2.4-2.45h1.95V4.1H6.69c-.44 0-.9.52-.82 1.11h4.05c1.39 0 2.99.48 2.99 2.67v2.2c2.07-3.56-.17-8.82-5.09-8.8-2.33 0-8.8 1.55-5.48 2.4 3.1.8-1.6 1.4-2.02 1.54m9.92 3.58c-.83-.01-1.48.04-1.48.64 0 .87 1.2.63 2.35.63V8.81z"/></svg>';
        var CIRCUMFERENCE = 131.95;
        var BTT_THRESHOLD = 400;

        function gs(key, fb) { try { var v = localStorage.getItem(key); return v !== null ? v : fb; } catch(e) { return fb; } }
        function getTheme() { var t = gs('color-theme','orange'); return THEMES.indexOf(t) !== -1 ? t : 'orange'; }

        /* ================================================================== */
        /*  CRITICAL PART — runs sync before first paint                      */
        /*  Zero forced-layout operations: only setAttribute and classList    */
        /* ================================================================== */
        var el = document.documentElement;
        var themeMeta = document.getElementById('theme-color-meta');
        if (themeMeta) themeMeta.content = TC[getTheme()] || '#ee4000';
        var mode = gs('theme','system');
        el.setAttribute('data-theme-mode', mode);
        el.setAttribute('data-theme', getTheme());
        if (mode === 'dark' || (mode === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          el.classList.add('dark');
        } else {
          el.classList.remove('dark');
        }

        /* ================================================================== */
        /*  DEFERRED PART — runs after window.load                            */
        /*  No scrollHeight/offsetHeight reads on critical path!              */
        /*  All geometry reads go through ResizeObserver only.                */
        /* ================================================================== */
        function onLoad() {
          window.removeEventListener('load', onLoad);

          /* ---- A. Favicon ---- */
          function updateFavicon() {
            var t = getTheme(), c = FC[t] || '#ee4000', svg = SVG_PREFIX + c + SVG_SUFFIX, uri;
            try { uri = 'data:image/svg+xml;base64,' + btoa(svg); } catch(e) { uri = 'data:image/svg+xml,' + encodeURIComponent(svg); }
            var existing = document.querySelectorAll('link[rel="icon"]');
            for (var i = 0; i < existing.length; i++) existing[i].remove();
            var link = document.createElement('link');
            link.rel = 'icon'; link.type = 'image/svg+xml'; link.href = uri;
            document.head.appendChild(link);
          }
          updateFavicon();

          var mql = window.matchMedia('(prefers-color-scheme: dark)');
          mql.addEventListener('change', function () {
            if (gs('theme','system') === 'system') el.classList.toggle('dark', mql.matches);
          });

          var timerId = null;
          new MutationObserver(function () {
            if (timerId) clearTimeout(timerId);
            timerId = setTimeout(updateFavicon, 200);
          }).observe(el, { attributes: true, attributeFilter: ['data-theme', 'data-theme-mode'] });

          document.addEventListener('astro:after-swap', function () {
            el.setAttribute('data-theme', getTheme());
            el.setAttribute('data-theme-mode', gs('theme','system'));
          });

          /* ---- B. Scroll-progress bar — ResizeObserver for scrollHeight ---- */
          (function() {
            var bar = document.getElementById('scroll-progress-bar');
            if (!bar) return;
            var maxY = 0, tick = false;
            function calc() { maxY = document.documentElement.scrollHeight - window.innerHeight; }
            if (typeof ResizeObserver !== 'undefined') {
              new ResizeObserver(function(){ requestAnimationFrame(calc); }).observe(document.documentElement);
            }
            function onScroll() {
              if (tick) return; tick = true;
              requestAnimationFrame(function(){ bar.style.width = (maxY > 0 ? (window.scrollY / maxY) * 100 : 0) + '%'; tick = false; });
            }
            window.addEventListener('scroll', onScroll, { passive: true });
            requestAnimationFrame(function(){ calc(); onScroll(); });
            document.addEventListener('astro:page-load', function(){ requestAnimationFrame(function(){ calc(); onScroll(); }); });
          })();

          /* ---- C. Back-to-top — same: ResizeObserver for scrollHeight ---- */
          (function() {
            var btn = document.getElementById('back-to-top');
            if (!btn || btn.dataset.bttInit) return; btn.dataset.bttInit = 'true';
            var ring = document.getElementById('back-to-top-ring');
            var rm = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            var maxY = 0, tick = false, vis = false;
            function calc() { maxY = document.documentElement.scrollHeight - window.innerHeight; }
            if (typeof ResizeObserver !== 'undefined') {
              new ResizeObserver(function(){ requestAnimationFrame(calc); }).observe(document.documentElement);
            }
            function show() {
              btn.style.transition = rm ? 'none' : 'opacity 250ms cubic-bezier(0,0,0.2,1), translate 250ms cubic-bezier(0,0,0.2,1)';
              btn.style.opacity = '1'; btn.style.translate = '0 0'; btn.style.pointerEvents = 'auto'; vis = true;
            }
            function hide() {
              btn.style.transition = rm ? 'none' : 'opacity 300ms cubic-bezier(0.4,0,1,1), translate 300ms cubic-bezier(0.4,0,1,1)';
              btn.style.opacity = '0'; btn.style.translate = '0 2rem'; btn.style.pointerEvents = 'none'; vis = false;
            }
            function frame() {
              var pct = maxY > 0 ? Math.min(1, Math.max(0, window.scrollY / maxY)) : 0;
              if (ring) ring.style.strokeDashoffset = String(CIRCUMFERENCE * (1 - pct));
              if (window.scrollY > BTT_THRESHOLD) { if (!vis) show(); } else { if (vis) hide(); }
              tick = false;
            }
            function onScroll() { if (!tick) { tick = true; requestAnimationFrame(frame); } }
            window.addEventListener('scroll', onScroll, { passive: true });
            btn.addEventListener('click', function(){ window.scrollTo({ top: 0, behavior: rm ? 'auto' : 'smooth' }); });
            document.addEventListener('astro:before-swap', function(){ window.removeEventListener('scroll', onScroll); }, { once: true });
            requestAnimationFrame(function(){ calc(); frame(); });
          })();

          /* ---- D. Scroll Reveal — IntersectionObserver, no forced layout ---- */
          (function() {
            var els = Array.prototype.slice.call(document.querySelectorAll('[data-reveal]:not(.is-visible), [data-reveal-children]:not(.is-visible)'));
            document.querySelectorAll('[data-reveal-content]').forEach(function(c){
              Array.prototype.forEach.call(c.children, function(ch){ if (!ch.classList.contains('is-visible')) els.push(ch); });
            });
            if (!els.length) return;

            // Lazy-load images that are below the fold.
            // Any <img> or <Image> inside a reveal element that is NOT
            // in the first visible batch gets loading="lazy" to reduce
            // the initial bandwidth footprint.
            function setLazyLoading(target) {
              var imgs = target.querySelectorAll('img');
              for (var i = 0; i < imgs.length; i++) {
                if (!imgs[i].hasAttribute('loading')) {
                  imgs[i].setAttribute('loading', 'lazy');
                  imgs[i].setAttribute('decoding', 'async');
                }
              }
            }

            var eager = document.body.hasAttribute('data-eager-reveal');
            var bfm = eager ? '0px 0px -5% 0px' : '0px 0px -10% 0px';
            var shortObs = new IntersectionObserver(function(entries){
              entries.forEach(function(e){
                if(e.isIntersecting){ e.target.classList.add('is-visible'); shortObs.unobserve(e.target); }
              });
            }, { threshold: 0.15, rootMargin: bfm });
            var tallObs = new IntersectionObserver(function(entries){
              entries.forEach(function(e){
                if(e.isIntersecting){ e.target.classList.add('is-visible'); tallObs.unobserve(e.target); }
              });
            }, { threshold: 0, rootMargin: bfm });
            var idx = 0;
            var fp = new IntersectionObserver(function(entries){
              entries.sort(function(a,b){ var p=a.target.compareDocumentPosition(b.target); return p&Node.DOCUMENT_POSITION_FOLLOWING?-1:p&Node.DOCUMENT_POSITION_PRECEDING?1:0; });
              entries.forEach(function(e){
                fp.unobserve(e.target);
                if(e.isIntersecting){
                  // Above-the-fold elements skip lazy loading
                  var i=idx++; setTimeout(function(){ e.target.classList.add('is-visible'); }, 250+i*80);
                } else {
                  // Below-the-fold: set lazy loading before observing
                  setLazyLoading(e.target);
                  var rb=e.rootBounds;
                  (rb&&e.boundingClientRect.height>rb.height*0.85?tallObs:shortObs).observe(e.target);
                }
              });
            }, { threshold: 0, rootMargin: '0px 0px -25% 0px' });
            els.forEach(function(e){ fp.observe(e); });
          })();

          /* ---- E. Service Worker ---- */
          if ('serviceWorker' in navigator) { navigator.serviceWorker.register('/sw.js').catch(function(){}); }
        }

        // Start after full page load. This is the only load listener in the entire layout.
        if (document.readyState === 'complete') { onLoad(); } else { window.addEventListener('load', onLoad); }
      })();
    </script>

    <!-- SEO -->
    <SEO
      title={title}
      description={description}
      image={image}
      imageAlt={imageAlt}
      article={article}
      noindex={noindex}
      nofollow={nofollow}
    />

    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.name} RSS Feed`} href={`${import.meta.env.BASE_URL}rss.xml`} />

    <!-- JSON-LD Structured Data -->
    <JsonLd schema={schemas} />

    <!-- Analytics (loads if PUBLIC_GA_MEASUREMENT_ID or PUBLIC_GTM_ID is set) -->
    <Analytics />

    <!-- Client-side view transitions are intentionally disabled. They composed
         poorly with the theme's CSS keyframe animations (hero slide-up,
         data-reveal fades) and produced a visible post-fade "aftershake" on
         mobile. Each navigation now does a normal page load, so animations
         run cleanly from frame 0 every time. -->
  </head>

  <body class="min-h-screen bg-background text-foreground antialiased" data-eager-reveal={eagerReveal ? '' : undefined}>
    <!-- Skip to content link -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-foreground"
    >
      Skip to content
    </a>

    <!-- Scroll progress bar -->
    <div
      id="scroll-progress-bar-container"
      class={"fixed left-0 z-[60] h-[2px] w-full overflow-hidden bg-transparent " + (scrollProgressAtTop ? "top-0" : "top-16")}
      aria-hidden="true"
    >
      <div
        id="scroll-progress-bar"
        class="h-full w-0 bg-brand-500 transition-none"
      />
    </div>

    <slot name="header" />

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <slot name="footer" />

    <ConsentBanner />

    <CursorTrail />

    <!-- Back to top button -->
    <button
      id="back-to-top"
      aria-label="Back to top"
      class="fixed bottom-9 right-8 sm:bottom-6 sm:right-6 z-50 h-12 w-12"
      style="opacity:0;translate:0 2rem;pointer-events:none"
    >
      <!-- Scroll-progress ring (rotated so arc starts at 12 o'clock) -->
      <svg class="absolute inset-0 h-full w-full -rotate-90" viewBox="0 0 48 48" aria-hidden="true">
        <!-- Faint grey track -->
        <circle cx="24" cy="24" r="21" fill="none" stroke="currentColor" class="text-border" stroke-width="2" opacity="0.5" />
        <!-- Brand progress arc -->
        <circle id="back-to-top-ring" cx="24" cy="24" r="21" fill="none" stroke="currentColor" class="text-brand-500" stroke-width="2.5" stroke-linecap="round" stroke-dasharray="131.95" stroke-dashoffset="131.95" />
      </svg>
      <!-- Inner face -->
      <span class="absolute inset-[5px] flex items-center justify-center rounded-full bg-background border border-border-strong text-foreground-muted shadow-md" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m18 15-6-6-6 6"/></svg>
      </span>
    </button>
  </body>
</html>
