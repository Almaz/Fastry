---
/**
 * 404 page — Russian (default)
 * Served by Netlify _redirects rule when a visitor lands on a non-existent URL.
 * This is the root 404.html served for all 404 errors.
 * Server-side renders in Russian (default locale).
 * Client-side JS detects /en/ prefix and swaps to English.
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import { localizedPath, t } from '@/i18n';

const locale = 'ru';

const badgeText = t('errors.404.badge', locale);
const headingPart = t('errors.404.titlePart', locale);
const headingHighlight = t('errors.404.titleHighlight', locale);
const description = t('errors.404.description', locale);
const recoveryTitle = t('errors.404.recoveryTitle', locale);

const homeLabel = t('errors.404.buttons.home', locale);
const blogLabel = t('errors.404.buttons.blog', locale);

const recoveryLinks = [
  {
    icon: 'layers',
    title: t('errors.404.links.projects.title', locale),
    description: t('errors.404.links.projects.description', locale),
    href: localizedPath('/projects', locale),
  },
  {
    icon: 'book',
    title: t('errors.404.links.blog.title', locale),
    description: t('errors.404.links.blog.description', locale),
    href: localizedPath('/blog', locale),
  },
  {
    icon: 'mail',
    title: t('errors.404.links.contact.title', locale),
    description: t('errors.404.links.contact.description', locale),
    href: localizedPath('/contact', locale),
  },
];

const homeHref = localizedPath('/', locale);
const blogHref = localizedPath('/blog', locale);
---

<PageLayout
  title={t('errors.pageNotFound', locale) + ' — ' + t('siteName', locale)}
  description={t('errors.pageNotFoundMessage', locale)}
  noindex
  eagerReveal
>
  <canvas id="bg-canvas" aria-hidden="true"></canvas>

  <Hero layout="centered" size="sm" class="!bg-transparent" data-reveal>
    <Badge slot="badge" variant="brand" pill>
      <Icon name="compass" size="sm" />
      <span id="404-badge">{badgeText}</span>
    </Badge>

    <h1 slot="title" id="404-heading">
      {headingPart} <span class="text-brand-500" id="404-heading-highlight">{headingHighlight}</span>
    </h1>

    <p slot="description" id="404-description">
      {description}
    </p>

    <div slot="actions" class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <Button href={homeHref} size="lg" id="404-home-btn">
        <Icon name="arrow-left" size="sm" />
        <span id="404-home-label">{homeLabel}</span>
      </Button>
      <Button href={blogHref} variant="outline" size="lg" id="404-blog-btn">
        <span id="404-blog-label">{blogLabel}</span>
        <Icon name="arrow-right" size="sm" />
      </Button>
    </div>
  </Hero>

  {/* Recovery Section */}
  <section class="py-[var(--space-section-md)] bg-background-secondary/80 backdrop-blur-sm border-t border-border relative z-10">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-8 text-center" data-reveal>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground" id="404-recovery-title">
          {recoveryTitle}
        </h2>
      </div>

      <div class="grid gap-6 lg:grid-cols-3" id="404-recovery-links">
        {recoveryLinks.map((link, i) => (
          <Card hover href={link.href} class="group" data-reveal data-reveal-delay={i}>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                <Icon name={link.icon} size="sm" />
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-base font-semibold text-foreground">{link.title}</h3>
                <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                  {link.description}
                </p>
              </div>
              <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors shrink-0" />
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>
</PageLayout>

<style is:global>
  body:has(#bg-canvas) {
    background-color: transparent !important;
  }

  body:has(#bg-canvas) main {
    background-color: transparent !important;
    position: relative;
    z-index: 1;
  }

  body:has(#bg-canvas) footer {
    position: relative;
    z-index: 1;
  }

  /* Dark mode: make body background dark so the canvas shows through
     instead of a white backdrop from global styles. */
  .dark body:has(#bg-canvas) {
    background-color: #0a0a0b !important;
  }

  .dark body:has(#bg-canvas) main {
    background-color: transparent !important;
  }

  /* Dark mode: slightly transparent dark background so the animated canvas
     shows through, matching the light-mode /80 treatment. */
  .dark body:has(#bg-canvas) section.bg-background-secondary\/80 {
    background-color: color-mix(in oklch, var(--color-background-secondary) 80%, transparent) !important;
  }

  #bg-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: block;
    z-index: 0;
    pointer-events: none;
  }
</style>

<script is:inline src="/scripts/404-bg.js"></script>

<script is:inline>
  /**
   * Client-side locale detection for the 404 page.
   * Netlify always serves the root 404.html regardless of the URL path,
   * so we must detect /en/ on the client and swap texts dynamically.
   *
   * Server-side renders in Russian (default locale).
   * If the URL starts with /en/, this script swaps all visible text to English.
   *
   * This also swaps Header and Footer navigation texts and links,
   * since those are rendered server-side with locale='ru'.
   */
  (function() {
    var path = window.location.pathname;
    if (!path.startsWith('/en')) return;

    // ── English translations ──────────────────────────────────────
    var enNav = {
      home: 'Home',
      services: 'Services',
      projects: 'Projects',
      blog: 'Blog',
      about: 'About',
      contact: 'Contact',
      startProject: 'Start a Project',
      navigate: 'Navigate',
      theme: 'Theme',
      colourTheme: 'Colour Theme',
      language: 'Language',
      connect: 'Connect',
      openMenu: 'Open menu',
      mainNavigation: 'Main navigation',
      mobileNavigation: 'Mobile navigation',
      homeTooltip: 'Go to homepage',
      followAlong: 'Follow along',
      siteName: 'Fastry',
    };

    var en404 = {
      badge: '404 — Page not found',
      titlePart: 'Page not',
      titleHighlight: 'found.',
      description: 'This page has been moved, deleted, or never existed. Let\'s get you back on track.',
      recoveryTitle: 'Try one of these sections',
      homeLabel: 'Go home',
      blogLabel: 'Visit blog',
      links: [
        { title: 'Projects', desc: 'Featured work and case studies.', href: '/en/projects' },
        { title: 'Blog', desc: 'Notes on design, code, and craft.', href: '/en/blog' },
        { title: 'Contact', desc: 'Start a conversation about your project.', href: '/en/contact' },
      ],
    };

    // ── Helper: map Russian href → English href ───────────────────
    function enHref(href) {
      if (href === '/' || href === '') return '/en';
      if (href.startsWith('/en')) return href;
      return '/en' + href;
    }

    // ── Helper: map Russian href → English nav label ──────────────
    function enNavLabel(href) {
      var map = {
        '/': enNav.home,
        '/en': enNav.home,
        '/services': enNav.services,
        '/en/services': enNav.services,
        '/projects': enNav.projects,
        '/en/projects': enNav.projects,
        '/blog': enNav.blog,
        '/en/blog': enNav.blog,
        '/about': enNav.about,
        '/en/about': enNav.about,
        '/contact': enNav.contact,
        '/en/contact': enNav.contact,
      };
      return map[href] || null;
    }

    // ── Helper: update a single nav link element ──────────────────
    function updateNavLink(link) {
      var href = link.getAttribute('href');
      var enText = enNavLabel(href);
      if (enText) {
        var childEls = link.querySelectorAll('*');
        if (childEls.length === 0) {
          link.textContent = enText;
        } else {
          link.childNodes.forEach(function(n) {
            if (n.nodeType === Node.TEXT_NODE && n.textContent.trim()) {
              n.textContent = enText;
            }
          });
        }
        link.setAttribute('href', enHref(href));
      }
    }

    // ── 1. Swap Header desktop nav links (.nav-link) ──────────────
    document.querySelectorAll('header a.nav-link').forEach(updateNavLink);

    // ── 2. Swap Header mobile menu links (.mobile-menu-row) ───────
    document.querySelectorAll('a.mobile-menu-row').forEach(function(link) {
      var href = link.getAttribute('href');
      var enText = enNavLabel(href);
      if (enText) {
        var textSpan = link.querySelector('span.flex-1');
        if (textSpan) {
          textSpan.textContent = enText;
        }
        link.setAttribute('href', enHref(href));
      }
    });

    // ── 3. Swap Header CTA button ─────────────────────────────────
    var ctaBtn = document.querySelector('header .hdr-cta-brand');
    if (ctaBtn) {
      ctaBtn.childNodes.forEach(function(n) {
        if (n.nodeType === Node.TEXT_NODE && n.textContent.trim()) {
          n.textContent = enNav.startProject;
        }
      });
      var ctaTextEl = ctaBtn.querySelector('span, div');
      if (ctaTextEl && !ctaTextEl.querySelector('svg, img, .icon')) {
        ctaTextEl.textContent = enNav.startProject;
      }
      var ctaHref = ctaBtn.getAttribute('href');
      if (ctaHref) ctaBtn.setAttribute('href', enHref(ctaHref));
    }

    // ── 4. Swap Header aria-labels ────────────────────────────────
    var menuBtn = document.querySelector('header button[aria-label*="Menu" i], header button[aria-label*="menu" i]');
    if (menuBtn) menuBtn.setAttribute('aria-label', enNav.openMenu);

    document.querySelectorAll('header nav[aria-label]').forEach(function(nav) {
      var label = nav.getAttribute('aria-label');
      if (label && label.toLowerCase().includes('navigation')) {
        nav.setAttribute('aria-label', enNav.mainNavigation);
      }
    });

    document.querySelectorAll('div[role="navigation"][aria-label]').forEach(function(nav) {
      var label = nav.getAttribute('aria-label');
      if (label && label.toLowerCase().includes('navigation')) {
        nav.setAttribute('aria-label', enNav.mobileNavigation);
      }
    });

    // ── 5. Swap Header data-i18n attributes ───────────────────────
    var headerEl = document.querySelector('header[data-i18n-navigate]');
    if (headerEl) {
      headerEl.setAttribute('data-i18n-navigate', enNav.navigate);
      headerEl.setAttribute('data-i18n-theme', enNav.theme);
    }

    // ── 6. Swap mobile menu labels ────────────────────────────────
    document.querySelectorAll('.mobile-menu-label').forEach(function(label) {
      var text = label.textContent.trim().toLowerCase();
      if (text === 'navigate' || text.includes('navigate')) {
        label.textContent = enNav.navigate;
      } else if (text === 'theme' || text.includes('theme')) {
        label.textContent = enNav.theme;
      } else if (text === 'connect' || text.includes('connect')) {
        label.textContent = enNav.connect;
      }
    });

    document.querySelectorAll('.mobile-menu-section span.text-sm').forEach(function(label) {
      var text = label.textContent.trim().toLowerCase();
      if (text.includes('colour') || text.includes('color') || text.includes('theme')) {
        label.textContent = enNav.colourTheme;
      } else if (text.includes('language')) {
        label.textContent = enNav.language;
      }
    });

    // ── 7. Swap Footer nav links ──────────────────────────────────
    document.querySelectorAll('footer nav a[href]').forEach(updateNavLink);

    // ── 8. Swap Footer copyright ──────────────────────────────────
    document.querySelectorAll('footer p').forEach(function(p) {
      var text = p.textContent || '';
      if (text.indexOf('©') !== -1 || text.indexOf('Fastry') !== -1) {
        p.textContent = text.replace(/Fastry/g, 'Fastry');
      }
    });

    // ── 9. Swap Footer logo link ──────────────────────────────────
    var footerLogoLink = document.querySelector('footer a[href="/"]');
    if (footerLogoLink) footerLogoLink.setAttribute('href', '/en');

    // ── 10. Swap Header logo link ─────────────────────────────────
    var headerLogoLink = document.querySelector('header a[href="/"]');
    if (headerLogoLink) headerLogoLink.setAttribute('href', '/en');

    // ── 11. Update header data-locale attribute ───────────────────
    var headerDataLocale = document.querySelector('header[data-locale]');
    if (headerDataLocale) headerDataLocale.setAttribute('data-locale', 'en');

    // ── 12. Swap 404 content ──────────────────────────────────────
    var en = en404;

    var badgeEl = document.getElementById('404-badge');
    if (badgeEl) badgeEl.textContent = en.badge;

    var headingEl = document.getElementById('404-heading');
    if (headingEl) {
      var highlightSpan = document.getElementById('404-heading-highlight');
      var nodes = headingEl.childNodes;
      for (var i = 0; i < nodes.length; i++) {
        if (nodes[i].nodeType === Node.TEXT_NODE && nodes[i].textContent.trim()) {
          nodes[i].textContent = en.titlePart + ' ';
          break;
        }
      }
      if (highlightSpan) highlightSpan.textContent = en.titleHighlight;
    }

    var descEl = document.getElementById('404-description');
    if (descEl) descEl.textContent = en.description;

    var recoveryEl = document.getElementById('404-recovery-title');
    if (recoveryEl) recoveryEl.textContent = en.recoveryTitle;

    var homeLabelEl = document.getElementById('404-home-label');
    if (homeLabelEl) homeLabelEl.textContent = en.homeLabel;

    var blogLabelEl = document.getElementById('404-blog-label');
    if (blogLabelEl) blogLabelEl.textContent = en.blogLabel;

    var homeBtn = document.getElementById('404-home-btn');
    if (homeBtn) homeBtn.setAttribute('href', '/en');

    var blogBtn = document.getElementById('404-blog-btn');
    if (blogBtn) blogBtn.setAttribute('href', '/en/blog');

    var linksContainer = document.getElementById('404-recovery-links');
    if (linksContainer) {
      var cards = linksContainer.querySelectorAll('[data-reveal]');
      for (var j = 0; j < cards.length && j < en.links.length; j++) {
        var card = cards[j];
        var titleEl = card.querySelector('h3');
        var descEl_ = card.querySelector('p');
        var linkEl = card.closest('a') || card.querySelector('a');
        if (titleEl) titleEl.textContent = en.links[j].title;
        if (descEl_) descEl_.textContent = en.links[j].desc;
        if (linkEl) linkEl.setAttribute('href', en.links[j].href);
      }
    }

    document.title = en.badge + ' — Fastry';
  })();
</script>