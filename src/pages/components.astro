---
import PageLayout from '@/layouts/PageLayout.astro';
// Компоненты форм
import Button from '@/components/ui/form/Button/Button.astro';
import Input from '@/components/ui/form/Input/Input.astro';
import Textarea from '@/components/ui/form/Textarea/Textarea.astro';
import Select from '@/components/ui/form/Select/Select.astro';
import Checkbox from '@/components/ui/form/Checkbox/Checkbox.astro';
import Radio from '@/components/ui/form/Radio/Radio.astro';
import Switch from '@/components/ui/form/Switch/Switch.astro';
// Компоненты отображения данных
import Card from '@/components/ui/data-display/Card/Card.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Avatar from '@/components/ui/data-display/Avatar/Avatar.astro';
import AvatarGroup from '@/components/ui/data-display/AvatarGroup/AvatarGroup.astro';
import Table from '@/components/ui/data-display/Table/Table.astro';
import Pagination from '@/components/ui/data-display/Pagination/Pagination.astro';
import Progress from '@/components/ui/data-display/Progress/Progress.astro';
import Skeleton from '@/components/ui/data-display/Skeleton/Skeleton.astro';
// Компоненты обратной связи
import Alert from '@/components/ui/feedback/Alert/Alert.astro';
import { ToastDemo } from '@/components/ui/feedback/Toast';
import Tooltip from '@/components/ui/feedback/Tooltip/Tooltip.astro';
// Компоненты перекрытий
import Dialog from '@/components/ui/overlay/Dialog/Dialog.astro';
import Dropdown from '@/components/ui/overlay/Dropdown/Dropdown.astro';
import Tabs from '@/components/ui/overlay/Tabs/Tabs.astro';
import VerticalTabs from '@/components/ui/overlay/VerticalTabs/VerticalTabs.astro';
import Accordion from '@/components/ui/overlay/Accordion/Accordion.astro';
// Компоненты макета
import Separator from '@/components/ui/layout/Separator/Separator.astro';
// Примитивы
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
// Маркетинговые компоненты
import CTA from '@/components/ui/marketing/CTA/CTA.astro';
import SocialProof from '@/components/ui/marketing/SocialProof/SocialProof.astro';
// Другие компоненты
import { Hero } from '@/components/hero';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import SearchInput from '@/components/patterns/SearchInput.astro';
import PasswordInput from '@/components/patterns/PasswordInput.astro';
import StatCard from '@/components/patterns/StatCard.astro';
import EmptyState from '@/components/patterns/EmptyState.astro';
// Landing Components
import StackMarquee from '@/components/landing/StackMarquee.astro';
---

<PageLayout
  title="Витрина компонентов"
  description="Изучите обширную библиотеку UI-компонентов Fastry. Готовые к использованию, доступные и красиво оформленные."
  noindex={true}
  footerBackground="secondary"
>

  <!-- Секция Hero -->
  <Hero layout="split" size="lg">
    <Badge slot="badge" variant="brand" pill>50+ готовых компонентов</Badge>

    <h1 slot="title">
      Библиотека <span class="text-brand-500">компонентов</span>
    </h1>

    <p slot="description">
      Готовые к использованию UI-примитивы, созданные с заботой о доступности и производительности.
      Копируйте, вставляйте и настраивайте под свой бренд.
    </p>

    <Fragment slot="actions">
      <Button href="#hero" class="hero-btn-brand">
        Просмотреть компоненты
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button href="https://github.com/hansmartensdev/Astro-Rocket" target="_blank" class="hero-btn-learn">
        <Icon name="github" size="sm" />
        Исходный код
      </Button>
    </Fragment>
  </Hero>



  <!-- Витрина компонентов -->
  <div class="mx-auto max-w-6xl px-6 py-20 space-y-32">

    <!-- Секция Hero -->
    <section id="hero" class="scroll-mt-32 flex flex-col gap-10">
      <div class="flex items-start gap-5">
        <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-brand-500/10 text-brand-500 shrink-0">
          <Icon name="star" size="lg" />
        </div>
        <div>
          <h2 class="font-display text-2xl font-bold text-foreground">Герой</h2>
          <p class="text-foreground-muted mt-1">Гибкие hero-секции с несколькими макетами, фонами и слотами для инъекции контента.</p>
        </div>
      </div>

      <div class="space-y-6">
        <!-- Hero - Разделенный макет -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Разделенный макет</span>
            <span class="showcase-hint">Две колонки со слотом aside</span>
          </div>
          <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
            <Hero layout="split" size="md" class="!pt-12 !pb-12">
              <Badge slot="badge" variant="brand" pill>Новый релиз</Badge>

              <h2 slot="title">
                Стройте быстрее с <span class="text-brand-500">Fastry</span>
              </h2>

              <p slot="description">
                Современный стартовый набор для production-сайтов.
              </p>

              <Fragment slot="actions">
                <Button size="sm">Начать</Button>
                <Button size="sm" variant="outline">Подробнее</Button>
              </Fragment>

              <div slot="aside" class="bg-background-secondary border border-border rounded-lg p-6 text-center">
                <Icon name="code" size="lg" class="text-brand-500 mx-auto mb-2" />
                <p class="text-sm text-foreground-muted">Слот для дополнительного контента</p>
              </div>

              <SocialProof
                class="mt-[var(--space-stack-lg)]"
                text="Доверяют разработчики"
                avatars={[
                  'https://i.pravatar.cc/150?img=12',
                  'https://i.pravatar.cc/150?img=33',
                  'https://i.pravatar.cc/150?img=47',
                ]}
              />
            </Hero>
          </div>
        </div>

        <!-- Hero - Центрированный макет -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Центрированный макет</span>
            <span class="showcase-hint">Одна колонка, выравнивание по центру</span>
          </div>
          <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
            <Hero layout="centered" size="md" class="!pt-12 !pb-12">
              <Badge slot="badge" variant="brand" pill>О нас</Badge>

              <h2 slot="title">
                У нас есть <span class="text-brand-500">миссия</span>
              </h2>

              <p slot="description">
                Создаём инструменты, которыми разработчики любят пользоваться. Наша команда стремится создавать исключительные решения.
              </p>

              <Fragment slot="actions">
                <Button size="sm">Познакомиться с командой</Button>
                <Button size="sm" variant="ghost">Наша история</Button>
              </Fragment>
            </Hero>
          </div>
        </div>

        <!-- Stack Marquee (double row) -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Stack Marquee</span>
            <span class="showcase-hint">Two rows of stack cards scrolling opposite ways — driven by src/content/stack, themed for light &amp; dark</span>
          </div>
          <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
            <div class="w-full py-[var(--space-stack-lg)]">
              <StackMarquee />
            </div>
          </div>
        </div>

        <!-- Сетка фонов Hero -->
        <div class="grid gap-6 lg:grid-cols-2">
          <!-- Фон второго уровня -->
          <div class="component-showcase">
            <div class="showcase-header">
              <span class="showcase-label">Фон второго уровня</span>
            </div>
            <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
              <Hero layout="split" size="sm" class="!pt-8 !pb-8 bg-surface-secondary">
                <h2 slot="title">Фон второго уровня</h2>
                <p slot="description">Лёгкое возвышение над фоном по умолчанию.</p>
              </Hero>
            </div>
          </div>

          <!-- Градиентный фон -->
          <div class="component-showcase">
            <div class="showcase-header">
              <span class="showcase-label">Градиентный фон</span>
            </div>
            <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
              <Hero layout="split" size="sm" class="!pt-8 !pb-8 bg-gradient-to-br from-background via-background to-background-secondary">
                <h2 slot="title">Градиентный фон</h2>
                <p slot="description">Эффект плавного градиентного перехода.</p>
              </Hero>
            </div>
          </div>
        </div>

        <!-- Инвертированный фон (на всю ширину) -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Инвертированный фон</span>
            <span class="showcase-hint">Всегда тёмный, независимо от темы</span>
          </div>
          <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
            <Hero layout="centered" size="sm" class="invert-section !pt-10 !pb-10 bg-background">
              <h2 slot="title">
                <span class="text-foreground">Тёмная тема </span><span class="text-brand-400">всегда</span>
              </h2>

              <p slot="description" class="text-foreground-secondary">
                Идеально подходит для CTA и секций, которые должны выделяться.
              </p>

              <Fragment slot="actions">
                <Button size="sm">Главное действие</Button>
                <Button size="sm" variant="outline">
                  Второстепенное
                </Button>
              </Fragment>

              <SocialProof
                class="mt-[var(--space-stack-lg)]"
                text="Присоединяйтесь к тысячам пользователей"
                avatars={[
                  'https://i.pravatar.cc/150?img=5',
                  'https://i.pravatar.cc/150?img=8',
                  'https://i.pravatar.cc/150?img=11',
                ]}
              />
            </Hero>
          </div>
        </div>

        <!-- Вариации размеров -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Вариации размеров</span>
            <span class="showcase-hint">параметры отступа sm, md, lg, xl</span>
          </div>
          <div class="showcase-content">
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
              {(['sm', 'md', 'lg', 'xl'] as const).map((size) => (
                <div class="border border-border rounded-lg overflow-hidden">
                  <div class="bg-background-secondary px-3 py-1.5 border-b border-border">
                    <span class="text-xs font-mono text-foreground-muted">size="{size}"</span>
                  </div>
                  <div class="bg-background text-center py-2">
                    <span class="text-xs text-foreground-subtle">
                      {size === 'sm' && 'Компактный отступ'}
                      {size === 'md' && 'Отступ по умолчанию'}
                      {size === 'lg' && 'Большой отступ'}
                      {size === 'xl' && 'Очень большой отступ'}
                    </span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Справка по параметрам -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Доступные параметры</span>
            <span class="showcase-hint">Упрощённый API (композиция прежде всего)</span>
          </div>
          <div class="showcase-content">
            <div class="grid gap-4 sm:grid-cols-2 text-sm">
              <div>
                <h4 class="font-semibold text-foreground mb-2">Параметры</h4>
                <ul class="space-y-1 text-foreground-muted">
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">layout</code> centered | split</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">size</code> sm | md | lg | xl</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">showGrid</code> boolean</li>
                </ul>
              </div>
              <div>
                <h4 class="font-semibold text-foreground mb-2">Слоты</h4>
                <ul class="space-y-1 text-foreground-muted">
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">badge</code> Используйте компонент Badge</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">title</code> Используйте h1/h2 напрямую</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">description</code> Используйте p напрямую</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">actions</code> Кнопки призыва к действию</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">aside</code> Боковой контент (только для split)</li>
                </ul>
              </div>
            </div>
            <p class="text-xs text-foreground-subtle mt-4">
              <strong>Фоны:</strong> Используйте CSS-классы для пользовательских фонов (например, <code class="bg-secondary px-1 rounded">class="bg-surface-invert"</code>)
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Секция Layout (Шапка и Подвал) -->
    <section id="layout" class="scroll-mt-32 flex flex-col gap-10">
      <div class="flex items-start gap-5">
        <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-brand-500/10 text-brand-500 shrink-0">
          <Icon name="layout" size="lg" />
        </div>
        <div>
          <h2 class="font-display text-2xl font-bold text-foreground">Макет</h2>
          <p class="text-foreground-muted mt-1">Компоненты шапки и подвала для единообразной структуры страницы. Варианты с полной кастомизацией через дизайн-токены.</p>
        </div>
      </div>

      <div class="space-y-6">
        <!-- Шапка: макет по умолчанию -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Макет по умолчанию</span>
            <span class="showcase-hint">Логотип слева, навигация + действия справа</span>
          </div>
          <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
            <Header
              position="static"
              showMobileMenu={false}
              showCta
              cta={{ label: 'Начать', href: '#' }}
              nav={[{ label: 'Возможности', href: '#' }, { label: 'Цены', href: '#' }, { label: 'Документация', href: '#' }, { label: 'Блог', href: '#' }]}
              actions={[{ icon: 'github', href: '#', label: 'GitHub', iconOnly: true }]}
            />
          </div>
        </div>

        <!-- Минимальный макет -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Минимальный макет</span>
            <span class="showcase-hint">Логотип + CTA, без навигации</span>
          </div>
          <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
            <Header
              layout="minimal"
              position="static"
              showMobileMenu={false}
              showCta
              cta={{ label: 'Войти', href: '#' }}
            />
          </div>
        </div>

        <!-- Только навигация (без действий) -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Только навигация</span>
            <span class="showcase-hint">Без CTA, без действий, только навигация</span>
          </div>
          <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
            <Header
              position="static"
              showMobileMenu={false}
              showThemeToggle={false}
              showCta={false}
              nav={[{ label: 'Главная', href: '#' }, { label: 'О нас', href: '#' }, { label: 'Услуги', href: '#' }, { label: 'Контакты', href: '#' }]}
            />
          </div>
        </div>

        <!-- Варианты размеров шапки -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Варианты размеров</span>
            <span class="showcase-hint">sm (48px), md (56px), lg (64px)</span>
          </div>
          <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
            <div class="divide-y divide-border">
              {(['sm', 'md', 'lg'] as const).map((size) => (
                <div>
                  <div class="bg-background-secondary/50 px-4 py-2 border-b border-border flex items-center justify-between">
                    <span class="text-xs font-mono text-foreground-muted">size="{size}"</span>
                    <span class="text-xs text-foreground-subtle">
                      {size === 'sm' && 'h-12 (48px) — компактный'}
                      {size === 'md' && 'h-14 (56px) — по умолчанию'}
                      {size === 'lg' && 'h-16 (64px) — просторный'}
                    </span>
                  </div>
                  <Header
                    position="static"
                    size={size}
                    showMobileMenu={false}
                    nav={[{ label: 'Возможности', href: '#' }, { label: 'Цены', href: '#' }, { label: 'Документация', href: '#' }]}
                    showCta
                    cta={{ label: 'Начать', href: '#' }}
                  />
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Варианты фона шапки -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Варианты фона</span>
            <span class="showcase-hint">default, solid, transparent</span>
          </div>
          <div class="showcase-content !p-0 overflow-hidden rounded-b-xl">
            <div class="divide-y divide-border">
              <!-- По умолчанию с размытием -->
              <div class="relative">
                <div class="absolute inset-0 bg-gradient-to-r from-brand-100 to-brand-200 dark:from-brand-900/30 dark:to-brand-800/30"></div>
                <div class="relative">
                  <div class="bg-background/80 backdrop-blur-sm px-4 py-2 border-b border-border">
                    <span class="text-xs font-mono text-foreground-muted">variant="default"</span>
                    <span class="text-xs text-foreground-subtle ml-2">— размытие фона + прозрачность</span>
                  </div>
                  <Header position="static" size="sm" variant="default" showMobileMenu={false} nav={[{ label: 'Главная', href: '#' }, { label: 'О нас', href: '#' }]} />
                </div>
              </div>
              <!-- Solid -->
              <div>
                <div class="bg-background-secondary/50 px-4 py-2 border-b border-border">
                  <span class="text-xs font-mono text-foreground-muted">variant="solid"</span>
                  <span class="text-xs text-foreground-subtle ml-2">— непрозрачный фон</span>
                </div>
                <Header position="static" size="sm" variant="solid" showMobileMenu={false} nav={[{ label: 'Главная', href: '#' }, { label: 'О нас', href: '#' }]} />
              </div>
              <!-- Прозрачный на светлом изображении -->
              <div class="relative overflow-hidden">
                <div
                  class="absolute inset-0 bg-cover bg-center grayscale brightness-150 opacity-60"
                  style="background-image: url('/photo-1506905925346-21bda4d32df4.jpeg');"
                ></div>
                <div class="absolute inset-0 bg-white/20"></div>
                <div class="relative">
                  <div class="bg-white/60 backdrop-blur-sm px-4 py-2 border-b border-black/10">
                    <span class="text-xs font-mono text-black/70">variant="transparent"</span>
                    <span class="text-xs text-black/50 ml-2">— светлый фон, тёмный текст</span>
                  </div>
                  <Header
                    position="static"
                    size="md"
                    variant="transparent"
                    showMobileMenu={false}
                    showCta
                    cta={{ label: 'Исследовать', href: '#' }}
                    nav={[{ label: 'Главная', href: '#' }, { label: 'Галерея', href: '#' }, { label: 'Контакты', href: '#' }]}
                  />
                </div>
              </div>
              <!-- Прозрачный на тёмном (инвертированные цвета) -->
              <div
                class="relative bg-cover bg-center"
                style="background-image: url('/photo-1451187580459-43490279c0fa.jpeg');"
              >
                <div class="absolute inset-0 bg-black/40"></div>
                <div class="relative">
                  <div class="bg-black/30 backdrop-blur-sm px-4 py-2 border-b border-white/10">
                    <span class="text-xs font-mono text-white/90">variant="transparent" colorScheme="invert"</span>
                    <span class="text-xs text-white/70 ml-2">— для тёмных фонов</span>
                  </div>
                  <Header
                    position="static"
                    size="md"
                    variant="transparent"
                    colorScheme="invert"
                    showMobileMenu={false}
                    showCta
                    cta={{ label: 'Исследовать', href: '#' }}
                    nav={[{ label: 'Главная', href: '#' }, { label: 'Галерея', href: '#' }, { label: 'Контакты', href: '#' }]}
                  />
                </div>
              </div>
            </div>
          </div>
        </div>


        <!-- Справка по параметрам шапки -->
        <div class="component-showcase">
          <div class="showcase-header">
            <span class="showcase-label">Параметры шапки</span>
            <span class="showcase-hint">Полный API</span>
          </div>
          <div class="showcase-content">
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 text-sm">
              <div>
                <h4 class="font-semibold text-foreground mb-2">Макет и позиция</h4>
                <ul class="space-y-1 text-foreground-muted">
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">layout</code> default | centered | minimal</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">position</code> fixed | sticky | static</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">size</code> sm | md | lg</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">variant</code> default | solid | transparent</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">colorScheme</code> default | invert</li>
                </ul>
              </div>
              <div>
                <h4 class="font-semibold text-foreground mb-2">Навигация</h4>
                <ul class="space-y-1 text-foreground-muted">
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">nav</code> NavItem[] (заменяет стандартные маршруты)</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">extraNav</code> NavItem[] (добавляет к маршрутам)</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">showActiveState</code> boolean</li>
                  <li><code class="text-xs bg-secondary px-1.5 py-0.5 rounded">showMobileMenu</code> boolean</li>
                </ul>
              </div>
              <div>
