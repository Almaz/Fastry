---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
import StackMarquee from '@/components/landing/StackMarquee.astro';
import { getCollection } from 'astro:content';
import siteConfig from '@/config/site.config';

const projectItems = await getCollection('projects');
const featuredProjects = projectItems
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const posts = (await getCollection('blog', ({ data, id }) => !data.draft && id.startsWith('ru/')))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf();
  })
  .slice(0, 4);
---

<LandingLayout
  title="Отличная основа для быстрого сайта"
  description="Готовая статическая платформа с 12 красивыми темами, 57+ компонентами, поддержкой перевода на иностранный язык, поиском, тёмным режимом и программным фундаментом на пике современных веб-технологий."
  image="/og-default.png"
  includePersonSchema={true}
  includeProfessionalServiceSchema={true}
>
  <!-- Hero -->
  <Hero layout="centered" size="xl" class="hero-dark-gradient" fullHeight showScrollIndicator>
    <Badge slot="badge" variant="brand" pill pulse class="dark:text-brand-200">Основа солидного сайта</Badge>

    <h1 slot="title" class="!text-[clamp(2rem,11.2vw,3rem)] sm:!text-5xl md:!text-6xl lg:!text-7xl">
      <span class="text-brand-600 dark:text-foreground [-webkit-text-fill-color:currentColor] whitespace-nowrap">Fastry ↯</span><br />
      <span class="text-brand-600 dark:text-foreground [-webkit-text-fill-color:currentColor]">молниеносный</span><br class="md:hidden" /><span class="text-brand-600 dark:text-foreground [-webkit-text-fill-color:currentColor]"> статический&nbsp;сайт</span>
    </h1>

    <p slot="description">
      готовая статическая платформа с поддержкой перевода на иностранный язык, поиском, тёмным режимом и программным фундаментом на пике современных веб-технологий.
    </p>

   <Fragment slot="actions">
      <Button size="lg" href="https://github.com/hansmartensdev/Astro-Rocket">
        Получить на GitHub
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button size="lg" variant="outline" href="/blog/astro-rocket-getting-started">
        <Icon name="rocket" size="sm" />
        Начать
        <Icon name="arrow-right" size="sm" />
      </Button>
    </Fragment>
  </Hero>

  <!-- Services Section / Platform capabilities -->
  <section id="content" class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Возможности платформы</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Что даёт Fastry
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto">
          От идеи до входа в топ выдачи.
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-3">
        <!-- Ready-to-use layouts -->
        <Card hover href="/services" class="group flex flex-col" data-reveal>
          <div class="flex items-start gap-4 sm:flex-col sm:items-center sm:gap-3 sm:text-center lg:flex-row lg:items-start lg:gap-4 lg:text-left">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="layout" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Готовые макеты</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                В комплекте 12 цветовых тем, 57+ компонентов и адаптивный дизайн из коробки. Внешний вид меняется под разное настроение в один клик.
              </p>
              <span class="inline-flex items-center gap-1 text-sm font-medium text-brand-500 mt-3 group-hover:gap-2 transition-all">
                Узнать больше
                <Icon name="arrow-right" size="sm" />
              </span>
            </div>
          </div>
        </Card>

        <!-- Modern stack -->
        <Card hover href="/services" class="group flex flex-col" data-reveal data-reveal-delay="1">
          <div class="flex items-start gap-4 sm:flex-col sm:items-center sm:gap-3 sm:text-center lg:flex-row lg:items-start lg:gap-4 lg:text-left">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="code" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Современный стек</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Astro 6, Tailwind CSS, TypeScript — всё предустановлено и оптимизировано. Лёгкое расширение функционала подключением компонентов.
              </p>
              <span class="inline-flex items-center gap-1 text-sm font-medium text-brand-500 mt-3 group-hover:gap-2 transition-all">
                Узнать больше
                <Icon name="arrow-right" size="sm" />
              </span>
            </div>
          </div>
        </Card>

        <!-- SEO & Performance -->
        <Card hover href="/services" class="group flex flex-col" data-reveal data-reveal-delay="2">
          <div class="flex items-start gap-4 sm:flex-col sm:items-center sm:gap-3 sm:text-center lg:flex-row lg:items-start lg:gap-4 lg:text-left">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="zap" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">SEO и скорость</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Максимальная оценка в сервисе Google для оценки качества пользовательского опыта на сайте. Автоматическая генерация структуры блога.
              </p>
              <span class="inline-flex items-center gap-1 text-sm font-medium text-brand-500 mt-3 group-hover:gap-2 transition-all">
                Узнать больше
                <Icon name="arrow-right" size="sm" />
              </span>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Portfolio / Use cases -->
  <section id="work" class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Проекты на Fastry</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Реальные решения
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto">
          Примеры сайтов, созданных на платформе.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {featuredProjects.map((project) => (
          <Card
            variant="elevated"
            hover
            padding="none"
            href={project.data.placeholder ? undefined : `/projects/${project.id.replace(/\.mdx?$/, '').replace('ru/', '')}`}
            class="group flex flex-col"
            data-reveal
          >
            <div class="flex flex-1 flex-col p-6">
              <div class="mb-3 flex items-start justify-between gap-4">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="layers" size="sm" />
                </div>
                <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors shrink-0 ml-auto" />
              </div>
              <div class="mb-2 flex items-baseline gap-2">
                <h3 class="font-display text-lg font-bold text-foreground">{project.data.title}</h3>
                {project.data.year && (
                  <span class="text-xs text-foreground-muted">{project.data.year}</span>
                )}
              </div>
              <p class="text-sm text-foreground-muted leading-relaxed mb-4 flex-1">{project.data.description}</p>
              {project.data.tags && project.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5">
                  {project.data.tags.map((tag) => (
                    <Badge variant="brand">{tag}</Badge>
                  ))}
                </div>
              )}
            </div>
          </Card>
        ))}
      </div>

      <div class="text-center mt-4">
        <Button variant="outline" href="/projects">
          Все проекты
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>

  <!-- Testimonials about the platform -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Отзывы о платформе</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Что говорят пользователи
          </h2>
        </div>
        <p class="text-lg text-foreground-muted">
          Разработчики и владельцы сайтов о Fastry.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        <!-- Testimonial 1: performance -->
        <Card variant="elevated" padding="lg" hover data-reveal>
          <div class="flex flex-col h-full gap-4">
            <div class="flex gap-1 text-brand-500" role="img" aria-label="5 из 5 звёзд">
              {[...Array(5)].map(() => (
                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="flex-1 text-foreground-muted leading-relaxed">
              «Мы перенесли сайт на Fastry — скорость загрузки выросла на 40%, а показатели Lighthouse стали 100/100. Статическая генерация и SEO-инструменты из коробки — настоящая находка».
            </blockquote>
            <div class="flex items-center gap-3 pt-4 border-t border-border">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-brand-500/30 to-brand-500/10 flex items-center justify-center text-brand-500 font-bold text-sm shrink-0">
                А
              </div>
              <div>
                <p class="text-sm font-semibold text-foreground">Алексей Воронов</p>
                <p class="text-xs text-foreground-muted">Технический директор, Bright Studio</p>
              </div>
            </div>
          </div>
        </Card>

        <!-- Testimonial 2: developer experience -->
        <Card variant="elevated" padding="lg" hover data-reveal data-reveal-delay="1">
          <div class="flex flex-col h-full gap-4">
            <div class="flex gap-1 text-brand-500" role="img" aria-label="5 из 5 звёзд">
              {[...Array(5)].map(() => (
                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="flex-1 text-foreground-muted leading-relaxed">
              «Больше не нужно настраивать Astro и Tailwind с нуля. Fastry даёт 57 готовых компонентов и 12 тем. Я запустил клиентский лендинг за пару часов, а миграция на новую тему заняла одну команду».
            </blockquote>
            <div class="flex items-center gap-3 pt-4 border-t border-border">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-brand-500/30 to-brand-500/10 flex items-center justify-center text-brand-500 font-bold text-sm shrink-0">
                С
              </div>
              <div>
                <p class="text-sm font-semibold text-foreground">Екатерина Морозова</p>
                <p class="text-xs text-foreground-muted">Lead Frontend, Luma Agency</p>
              </div>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- About Teaser → Platform philosophy -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-10 glitch:grid-cols-2 glitch:gap-12">
        <div class="flex flex-col justify-center sm:items-center sm:text-center glitch:items-start glitch:text-left" data-reveal="right" data-reveal-ease="smooth">
          <div class="flex flex-col gap-6 mb-6 sm:items-center glitch:items-start">
            <Badge variant="brand" pill class="self-start sm:self-center glitch:self-start">Философия платформы</Badge>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
              Статическая, быстрая,<br />
              <span class="text-brand-500">SEO-готовая.</span>
            </h2>
          </div>
          <p class="text-lg text-foreground-muted leading-relaxed text-pretty mb-4 sm:mb-0 sm:max-w-xl glitch:mb-4 glitch:max-w-none">
           Fastry генерирует статические страницы, которые загружаются мгновенно. Высокая производительность нравится не только людям, но и поисковикам, а модульная архитектура позволяет легко масштабировать сайт.
          </p>
          <p class="text-lg text-foreground-muted leading-relaxed text-pretty mb-8 sm:max-w-xl glitch:max-w-none sm:hidden glitch:block">
           В блоге детально рассказываются, как устроены различные функции сайта, для чего нужны и каких результатов позволяют достигать.
          </p>
           <Button variant="outline" href="/blog" class="self-start sm:self-center glitch:self-start sm:hidden glitch:inline-flex">
            Почитать о функциях Fastry
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
        <Card variant="elevated" padding="lg" class="h-full flex flex-col" data-reveal="left" data-reveal-delay="1" data-reveal-ease="smooth">
          <h3 class="text-sm font-semibold text-foreground mb-5 text-center sm:hidden glitch:block">Ключевые особенности платформы</h3>
          <div class="grid grid-cols-2 sm:grid-cols-4 glitch:grid-cols-2 gap-3 flex-1 auto-rows-fr">
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="zap" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">Статическая генерация</p>
            </div>
             <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="search" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">Контекстный поиск</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="globe" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">Локализуемость</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center justify-center text-center gap-2 border-t-2 border-brand-500/40 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default h-full">
              <Icon name="expand" class="w-10 h-10 text-brand-500" />
              <p class="text-sm font-semibold text-foreground">Масштабируемость<br class="sm:hidden" /></p>
            </div>
          </div>
        </Card>
        <div class="hidden sm:flex justify-center glitch:hidden" data-reveal data-reveal-delay="2">
          <Button variant="outline" href="/about">
            Подробнее о Fastry
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-6 text-center" data-reveal>
        <Badge variant="brand" pill>Из блога</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Рекомендуемое
        </h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((post, index) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            href={`/blog/${post.id.replace('ru/', '')}`}
            publishedAt={post.data.publishedAt}
            tags={post.data.tags}
            author={post.data.author}
            image={post.data.image}
            svgSlug={post.data.svgSlug}
            class={index === 3 ? 'hidden sm:block lg:hidden' : undefined}
          />
        ))}
      </div>

      <div class="flex justify-center">
        <Button variant="outline" href="/blog">
          Все записи
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>

 <!-- Tech stack marquee -->
  <section class="stack-marquee-section relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Технологии</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Современный технологический стек
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto">
          Fastry построен на проверенных технологиях для максимальной производительности.
        </p>
      </div>

      <div data-reveal data-reveal-delay="1">
        <StackMarquee />
      </div>
    </div>
  </section>

 <!-- CTA - Ready to use -->
  <section class="cta-section relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <!-- Mobile: flat section, no card -->
    <div class="glitch:hidden mx-auto max-w-2xl px-6 text-center" data-reveal>
      <Badge variant="brand" pill class="mb-6">Готов к использованию</Badge>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Готовы к запуску?
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Fastry — это готовый фундамент. Разверните свой проект за минуты и сосредоточьтесь на контенте.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="/contact" class="cta-btn-brand">
          Начать с Fastry
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href="/about">
          Документация
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>

    <!-- Desktop: contained LetterGlitch band with glass card -->
    <LetterGlitchBand locale="ru">
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Готовы к запуску?
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Fastry — это готовый фундамент. Разверните свой проект за минуты и сосредоточьтесь на контенте.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="/contact" class="hero-btn-brand">
          Начать с Fastry
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href="/about">
          Документация
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </LetterGlitchBand>
  </section>

<script>
  function initCountup() {
    const counters = document.querySelectorAll<HTMLElement>('[data-countup]:not([data-countup-init])');
    if (counters.length === 0) return;
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        observer.unobserve(entry.target);
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.countup ?? '0', 10);
        const suffix = el.dataset.suffix ?? '';
        const duration = 1200;
        const start = performance.now();
        const tick = (now: number) => {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.round(eased * target) + suffix;
          if (progress < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      });
    }, { threshold: 0.4 });
    counters.forEach((el) => {
      el.dataset.countupInit = 'true';
      observer.observe(el);
    });
  }

  initCountup();
</script>

<style is:global>
  /* Widen the homepage hero description from md upward so the paragraph
     reads on two lines instead of three on landscape phones, tablets,
     and all laptop/desktop sizes. Scoped via the unique
     .hero-dark-gradient class so other heroes keep the default
     max-w-xl reading measure. */
  @media (min-width: 768px) {
    .hero-dark-gradient .hero-title-slot + div {
      max-width: 48rem;
    }
  }

  /* Mobile-phone zebra swap. On phones — portrait (caught by width) and
     landscape (wider than the md breakpoint, so caught by short height + a
     coarse/touch pointer, which excludes tablets and laptops) — the marquee
     band is hidden and the CTA + footer revert to their no-marquee colours.
     The default (tablet/desktop, marquee shown) order is:
       Blog(secondary) → Marquee(background) → CTA(secondary) → Footer(background)
     and on phones it collapses to:
       Blog(secondary) → CTA(background) → Footer(secondary)
     so every adjacent section alternates in both states. The element+class
     selectors outrank the Tailwind bg utilities, so no !important is needed. */
  @media (max-width: 767px) {
    .stack-marquee-section { display: none; }
    section.cta-section { background-color: var(--color-background); }
    footer.home-footer { background-color: var(--color-background-secondary); }
  }
  @media (orientation: landscape) and (max-height: 500px) and (pointer: coarse) {
    .stack-marquee-section { display: none; }
    section.cta-section { background-color: var(--color-background); }
    footer.home-footer { background-color: var(--color-background-secondary); }
  }
</style>

