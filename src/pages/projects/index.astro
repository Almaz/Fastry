---
/**
 * Projects page (Russian)
 * URL: /projects
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { Hero } from '@/components/hero';
import { getCollection } from 'astro:content';

const items = await getCollection('projects', ({ data }) => {
  return data.locale === 'ru' && !data.draft && !data.placeholder;
});
const projects = items.sort((a, b) => a.data.order - b.data.order);
---

<PageLayout title="Проекты — Fastry" description="Проекты, которые я создал." eagerReveal>
  <Hero layout="centered" size="sm" class="isolate" showHeroHalo>
    <Badge slot="badge" variant="brand" pill>
      <Icon name="layers" size="sm" />
      Проекты
    </Badge>

    <h1 slot="title">Проекты</h1>

    <p slot="description">Проекты, которые я создал.</p>
  </Hero>

  <section class="bg-background-secondary py-[var(--space-section-md)] border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      {
        projects.length > 0 ? (
          <div class="grid gap-6 md:grid-cols-2">
            {projects.map((project) => (
              <Card
                variant="elevated"
                hover
                padding="none"
                href={'/projects/' + project.id.replace(/ru\//, '')}
                class="group flex flex-col"
              >
                <div class="flex flex-1 flex-col p-6">
                  <div class="mb-3 flex items-start justify-between gap-4">
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                      <Icon name="layers" size="sm" />
                    </div>
                    <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors shrink-0 ml-auto" />
                  </div>
                  <div class="mb-2 flex items-baseline gap-2">
                    <h3 class="font-display text-lg font-bold text-foreground">{project.data.title}</h3>
                    {project.data.year && (
                      <span class="text-xs text-foreground-muted">{project.data.year}</span>
                    )}
                  </div>
                  <p class="text-sm text-foreground-muted leading-relaxed mb-4 flex-1 line-clamp-3">{project.data.description}</p>
                  {project.data.tags && project.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1.5">
                      {project.data.tags.map((tag) => (
                        <Badge variant="brand">{tag}</Badge>
                      ))}
                    </div>
                  )}
                </div>
              </Card>
            ))}
          </div>
        ) : (
          <div class="py-16 text-center">
            <div class="bg-background mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full">
              <Icon name="folder" size="lg" class="text-foreground-muted" />
            </div>
            <p class="text-foreground-muted text-lg">Проектов не найдено.</p>
          </div>
        )
      }
    </div>
  </section>
</PageLayout>
