---
/**
 * About page
 * URL: /about
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import TypingEffect from '@/components/ui/TypingEffect.astro';
import TechStack from '@/components/landing/TechStack.astro';
import LetterGlitchBand from '@/components/patterns/LetterGlitchBand.astro';
---
<PageLayout
  title="О проекте — Astro Rocket — стартовая тема для Astro 6"
  description="Astro Rocket — это готовая к работе стартовая тема для Astro 6 с 12 темами, 57+ компонентами, встроенной i18n, тёмной темой и всем необходимым для быстрого запуска."
  footerBackground="secondary"
>
  <Hero layout="centered" size="sm" class="isolate" showHeroHalo>
    <Badge slot="badge" variant="brand" pill>
      <Icon name="rocket" size="sm" />
      О проекте
    </Badge>
    <h1 slot="title">
      <span class="text-foreground [-webkit-text-fill-color:currentColor]">Astro Rocket —</span><br />
      <span class="text-brand-500 [-webkit-text-fill-color:var(--color-brand-500)]">
        <TypingEffect words={["Стартовая тема Astro 6", "Готова к эксплуатации", "12 тем", "57+ компонентов", "Тёмная тема", "Встроенная i18n", "SEO без настроек"]} />
      </span>
    </h1>

    <p slot="description">
      Бесплатная, готовая к работе стартовая тема для Astro 6, в которой есть всё для быстрой разработки современных сайтов — без необходимости начинать с нуля.
    </p>
  </Hero>

  <!-- О теме -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-10 glitch:grid-cols-2 glitch:gap-12">
        <!-- Левый: текст -->
        <div class="flex flex-col justify-center gap-4 sm:items-center sm:text-center glitch:items-start glitch:text-left" data-reveal="right" data-reveal-ease="smooth">
          <div class="flex flex-col gap-6 sm:items-center glitch:items-start">
            <Badge variant="brand" pill class="self-start sm:self-center glitch:self-start">Бесплатно и с открытым кодом</Badge>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground text-balance">
              Надёжный фундамент для любого проекта
            </h2>
          </div>
          <p class="text-lg text-foreground-muted leading-relaxed text-pretty sm:max-w-xl sm:mx-auto glitch:max-w-none glitch:mx-0">
            Astro Rocket — это готовая к работе стартовая тема, построенная на Astro 6. Она включает полную библиотеку компонентов, 12 ручной работы тем, тёмную тему, встроенную i18n и блог — чтобы вы могли сосредоточиться на своём проекте, а не на шаблонном коде.
          </p>
          <p class="text-lg text-foreground-muted leading-relaxed text-pretty sm:max-w-xl sm:mx-auto glitch:max-w-none glitch:mx-0">
            Она бесплатна, распространяется по лицензии MIT и добавлена в официальный каталог тем Astro. Клонируйте, настраивайте и публикуйте то, чем будете гордиться.
          </p>
        </div>
        <!-- Правый: карточка с фактами о теме -->
        <div class="flex flex-col h-full" data-reveal="left" data-reveal-delay="1" data-reveal-ease="smooth">
          <Card variant="elevated" padding="lg" class="flex-1 flex flex-col justify-center">
            <div class="grid grid-cols-2 sm:grid-cols-3 glitch:grid-cols-2 gap-x-6 gap-y-8">
              <div class="flex flex-col items-center text-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="rocket" size="md" />
                </div>
                <div>
                  <h3 class="text-base font-semibold text-foreground">Astro 6</h3>
                  <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                    Построена на последнем релизе Astro.
                  </p>
                </div>
              </div>
              <div class="flex flex-col items-center text-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="layout" size="md" />
                </div>
                <div>
                  <h3 class="text-base font-semibold text-foreground">12 тем</h3>
                  <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                    Смена темы одной строкой.
                  </p>
                </div>
              </div>
              <div class="flex flex-col items-center text-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="code-2" size="md" />
                </div>
                <div>
                  <h3 class="text-base font-semibold text-foreground">57+ компонентов</h3>
                  <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                    Комбинируемые, готовые к работе.
                  </p>
                </div>
              </div>
              <div class="flex flex-col items-center text-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="sparkles" size="md" />
                </div>
                <div>
                  <h3 class="text-base font-semibold text-foreground">Тёмная тема</h3>
                  <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                    Встроена, не требует настройки.
                  </p>
                </div>
              </div>
              <div class="flex flex-col items-center text-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="award" size="md" />
                </div>
                <div>
                  <h3 class="text-base font-semibold text-foreground">Встроенная i18n</h3>
                  <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                    Поддержка нескольких языков из коробки.
                  </p>
                </div>
              </div>
              <div class="flex flex-col items-center text-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="zap" size="md" />
                </div>
                <div>
                  <h3 class="text-base font-semibold text-foreground">SEO без настроек</h3>
                  <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                    Включены структурированные данные и метатеги.
                  </p>
                </div>
              </div>
            </div>
          </Card>
        </div>
      </div>
    </div>
  </section>

  <!-- Принципы -->
  <section class="py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-8 text-center flex flex-col items-center gap-4" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Принципы дизайна</Badge>
          <h2 class="font-display text-4xl font-bold text-foreground">
            Создано с намерением
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto text-balance">
          Каждое решение в Astro Rocket — от структуры компонентов до настроек по умолчанию — продиктовано тремя принципами.
        </p>
      </div>
      <div class="grid gap-6 sm:gap-8 sm:grid-cols-3">
        <Card hover data-reveal>
          <div class="flex items-start gap-4 sm:flex-col sm:items-center sm:gap-3 sm:text-center lg:flex-row lg:items-start lg:gap-4 lg:text-left">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="zap" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Производительность прежде всего</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                По умолчанию — ноль JavaScript. Каждый компонент оптимизирован для скорости, Core Web Vitals и минимального вывода.
              </p>
            </div>
          </div>
        </Card>
        <Card hover data-reveal data-reveal-delay="1">
          <div class="flex items-start gap-4 sm:flex-col sm:items-center sm:gap-3 sm:text-center lg:flex-row lg:items-start lg:gap-4 lg:text-left">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="award" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Опыт разработчика</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                TypeScript на всём пути, разумные настройки по умолчанию и библиотека компонентов, которую можно сразу вставить на любую страницу.
              </p>
            </div>
          </div>
        </Card>
        <Card hover data-reveal data-reveal-delay="2">
          <div class="flex items-start gap-4 sm:flex-col sm:items-center sm:gap-3 sm:text-center lg:flex-row lg:items-start lg:gap-4 lg:text-left">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="rocket" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Современная с самого начала</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Astro 6, Tailwind CSS 4 и чистая архитектура, которую легко расширять и поддерживать.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Технологический стек -->
  <TechStack
    badge="Инструменты и технологии"
    title="Стек"
    description="Технологии, лежащие в основе Astro Rocket — выбраны за производительность, отличный опыт разработчика и долгосрочную надёжность."
    background="secondary"
  />

  <!-- Часто задаваемые вопросы -->
  <section class="py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Полезно знать</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Часто задаваемые вопросы
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto text-balance">
          Всё, что нужно знать перед началом работы.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        <!-- Карточка 1: Об Astro -->
        <Card variant="elevated" padding="lg" data-reveal data-reveal-delay="1">
          <div class="flex items-center gap-3 pb-4 border-b border-border">
            <div class="w-11 h-11 rounded-lg bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="rocket" size="md" />
            </div>
            <h3 class="font-display text-base font-semibold text-foreground">Об Astro</h3>
          </div>
          <div class="w-full">
            <details class="border-b border-border" name="faq-astro">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Что такое Astro?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Astro — это современный веб-фреймворк, созданный для сайтов с контентом. По умолчанию он не отправляет JavaScript, отдавая только то, что действительно нужно странице. Результат — быстрая загрузка, отличные показатели Core Web Vitals и поддерживаемый код.
              </div>
            </details>
            <details class="border-b border-border" name="faq-astro">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Зачем использовать Astro?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Astro — правильный инструмент для контентно-ориентированных сайтов: минимальный JavaScript, чистый HTML, отличное SEO из коробки и опыт разработки, который не мешает. Он лёгкий, целенаправленный и создан на годы.
              </div>
            </details>
            <details class="border-b border-border" name="faq-astro">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Что можно построить с помощью Astro Rocket?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Портфолио, сайты бизнеса, маркетинговые страницы, блоги, документацию — любой контентно-ориентированный проект. Astro Rocket даёт структуру, компоненты и настройки, чтобы начать работу с лёгкостью.
              </div>
            </details>
            <details class="border-b border-border" name="faq-astro">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Добавлена ли Astro Rocket в официальный каталог тем Astro?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Да. <a href="https://astro.build/themes/details/astro-rocket/" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 decoration-brand-500 hover:text-brand-400 transition-colors">Astro Rocket</a> добавлена в официальный каталог тем Astro как бесплатная, готовая к работе тема.
              </div>
            </details>
            <details class="border-b border-border last:border-0" name="faq-astro">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Будет ли Astro Rocket обновляться вслед за новыми версиями Astro?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Да. Astro Rocket активно поддерживается и обновляется в соответствии с новыми релизами Astro. Следите за обновлениями в блоге или наблюдайте за репозиторием на GitHub.
              </div>
            </details>
          </div>
        </Card>

        <!-- Карточка 2: Использование темы -->
        <Card variant="elevated" padding="lg" data-reveal data-reveal-delay="2">
          <div class="flex items-center gap-3 pb-4 border-b border-border">
            <div class="w-11 h-11 rounded-lg bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="code-2" size="md" />
            </div>
            <h3 class="font-display text-base font-semibold text-foreground">Использование темы</h3>
          </div>
          <div class="w-full">
            <details class="border-b border-border" name="faq-theme">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Она бесплатна для использования?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Да, полностью бесплатна. Astro Rocket распространяется по лицензии MIT — используйте её в личных и коммерческих проектах, указание авторства не требуется.
              </div>
            </details>
            <details class="border-b border-border" name="faq-theme">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Как переключать темы?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Измените одну строку в конфигурации. Astro Rocket поставляется с 12 цветовыми темами ручной работы — переключайтесь между ними мгновенно, не касаясь ни строчки CSS.
              </div>
            </details>
            <details class="border-b border-border" name="faq-theme">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Поддерживается ли TypeScript?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Да, TypeScript используется повсеместно. Все компоненты, конфигурации и утилиты имеют полную типизацию.
              </div>
            </details>
            <details class="border-b border-border" name="faq-theme">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Как добавить свой язык для i18n?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                i18n в Astro Rocket управляется через конфигурацию. Добавьте свою локаль в файл конфигурации i18n, создайте соответствующий файл перевода, и маршрутизация с интерфейсом адаптируются автоматически.
              </div>
            </details>
            <details class="border-b border-border last:border-0" name="faq-theme">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Куда сообщать об ошибках или предлагать идеи?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Откройте issue или начните обсуждение в <a href="https://github.com/hansmartensdev/astro-rocket" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 decoration-brand-500 hover:text-brand-400 transition-colors">репозитории на GitHub</a>. Вклад и обратная связь всегда приветствуются.
              </div>
            </details>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Открытый код -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-8 sm:gap-10 glitch:grid-cols-2 glitch:items-center">
        <!-- Текст -->
        <div class="flex flex-col gap-4 sm:items-center sm:text-center glitch:items-start glitch:justify-center glitch:text-left" data-reveal="right" data-reveal-ease="smooth">
          <Badge variant="brand" pill class="self-start sm:self-center glitch:self-start">Открытый код</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Создано на виду
          </h2>
          <p class="text-lg text-foreground-muted leading-relaxed text-pretty sm:max-w-xl sm:mx-auto glitch:max-w-none glitch:mx-0">
            Astro Rocket — бесплатная, открытая тема с лицензией MIT. Изучайте исходный код, открывайте issues, отправляйте PR или просто клонируйте и создавайте что-то замечательное.
          </p>
          <Button variant="outline" size="lg" href="https://github.com/hansmartensdev/astro-rocket" target="_blank" rel="noopener noreferrer" class="self-start sm:self-center glitch:self-start mt-2">
            Смотреть на GitHub
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>

        <!-- Информационная карточка -->
        <div class="flex flex-col h-full" data-reveal="left" data-reveal-delay="1" data-reveal-ease="smooth">
          <Card variant="elevated" padding="lg" class="flex-1 flex flex-col justify-center gap-6">
            <div class="flex flex-col gap-2">
              <h3 class="text-base font-semibold text-foreground">Создано Хансом Мартенсом</h3>
