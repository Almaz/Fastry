---
import { t, getLocaleFromPath } from '@/i18n';

/**
 * PagefindSearch — Search modal with Pagefind integration
 * Uses @pagefind/default-ui for the search interface
 */
const locale = getLocaleFromPath(Astro.url.pathname);
const searchLabel = t('common.search', locale);
const searchModalTitle = t('common.searchModalTitle', locale);
const searchPlaceholder = t('common.searchPlaceholder', locale);
---

{
  /* Search toggle button */
}
<button
  id="pagefind-search-btn"
  class="pagefind-search-btn ttg-trigger inline-flex items-center gap-1.5 rounded-full border border-border-strong px-2.5 h-8 text-foreground-muted hover:text-foreground hover:bg-secondary transition-colors duration-(--transition-fast) focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
  aria-label={searchLabel}
  title={`${searchLabel} (Ctrl+K)`}
  data-search-label={searchLabel}
  data-search-modal-title={searchModalTitle}
  data-search-placeholder={searchPlaceholder}
>
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="11" cy="11" r="8"/>
    <path d="m21 21-4.3-4.3"/>
  </svg>
</button>

<style is:global>
  /* ===== Header search button ===== */
  .pagefind-search-btn {
    color: var(--color-foreground-muted);
  }
  .pagefind-search-btn:hover {
    color: var(--color-foreground);
    background-color: color-mix(in oklch, var(--color-secondary) 70%, transparent);
  }

  /* ===== Pagefind default UI — themed ===== */
  .pagefind-ui {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--color-foreground);
    --pagefind-ui-text: var(--color-foreground-muted);
    --pagefind-ui-background: var(--color-background);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-tag: var(--color-secondary);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 0.75rem;
    --pagefind-ui-image-border-radius: 0.5rem;
    --pagefind-ui-image-box-ratio: 3 / 2;
    --pagefind-ui-font: inherit;
  }

  .pagefind-ui__search-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .pagefind-ui__search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    width: 18px;
    height: 18px;
    color: var(--color-foreground-subtle);
    pointer-events: none;
    flex-shrink: 0;
  }

  .pagefind-ui__search-input {
    font-size: 1rem;
    padding: 0.75rem 1rem 0.75rem 2.75rem;
    border-radius: var(--radius-xl);
    background: color-mix(in oklch, var(--color-secondary) 50%, transparent);
    border: 1px solid var(--color-border);
    color: var(--color-foreground);
    width: 100%;
    transition: border-color 150ms, box-shadow 150ms;
  }
  .pagefind-ui__search-input:focus {
    outline: none;
    border-color: var(--color-brand-500);
    box-shadow: 0 0 0 3px color-mix(in oklch, var(--color-brand-500) 20%, transparent);
  }
  .pagefind-ui__search-input::placeholder {
    color: var(--color-foreground-subtle);
  }

  .pagefind-ui__search-kbd {
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.125rem 0.375rem;
    font-size: 0.6875rem;
    font-family: inherit;
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-foreground-subtle);
    background: color-mix(in oklch, var(--color-secondary) 60%, transparent);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    pointer-events: none;
    flex-shrink: 0;
  }

  .pagefind-ui__search-clear {
    color: var(--color-foreground-muted);
  }

  .pagefind-ui__result {
    display: block;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 1rem;
    margin-bottom: 0.75rem;
    background: var(--color-background);
    transition: border-color 150ms, box-shadow 150ms;
    text-decoration: none;
    color: inherit;
  }
  .pagefind-ui__result:hover {
    border-color: var(--color-brand-500);
    box-shadow: 0 2px 8px color-mix(in oklch, var(--color-brand-500) 10%, transparent);
  }

  .pagefind-ui__result-title {
    color: var(--color-brand-700);
    font-weight: 600;
    font-size: 1.05rem;
  }
  html.dark .pagefind-ui__result-title {
    color: var(--color-brand-300);
  }
  .pagefind-ui__result-excerpt {
    color: var(--color-foreground-muted);
    font-size: 0.875rem;
    line-height: 1.6;
    margin-top: 0.375rem;
  }
  .pagefind-ui__result-excerpt mark {
    background: color-mix(in oklch, var(--color-brand-500) 20%, transparent);
    color: var(--color-foreground);
    border-radius: 0.25rem;
    padding: 0.05rem 0.2rem;
  }

  .pagefind-ui__message {
    color: var(--color-foreground-subtle);
    font-size: 0.875rem;
    margin-bottom: 0.75rem;
  }

  .pagefind-ui__results {
    margin-top: 0.75rem;
  }

  .pagefind-ui__drawer {
    margin-top: 1rem;
  }

  /* ===== Search modal ===== */
  .pagefind-modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 999;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 6rem 1rem 2rem;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms ease;
  }
  .pagefind-modal-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }

  .pagefind-modal {
    width: 100%;
    max-width: 960px;
    max-height: calc(100vh - 8rem);
    overflow-y: auto;
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15), 0 8px 24px rgba(0, 0, 0, 0.08);
    padding: 1.25rem;
    transform: translateY(-12px);
    transition: transform 200ms ease;
  }
  .open .pagefind-modal {
    transform: translateY(0);
  }

  .pagefind-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }
  .pagefind-modal-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-foreground);
    letter-spacing: -0.01em;
  }
  .pagefind-modal-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    color: var(--color-foreground-muted);
    transition: background 150ms, color 150ms;
    cursor: pointer;
    background: transparent;
    border: none;
  }
  .pagefind-modal-close:hover {
    background: var(--color-secondary);
    color: var(--color-foreground);
  }

  /* ===== Hide Pagefind default thumbnail ===== */
  .pagefind-ui__result-thumb {
    display: none;
  }

  /* ===== Search progress indicator ===== */
  .pagefind-search-progress {
    height: 0;
    overflow: hidden;
    transition: height 200ms ease;
  }

  .pagefind-search-progress--active {
    height: 6px;
  }

  .pagefind-search-progress__track {
    position: relative;
    width: 100%;
    height: 4px;
    overflow: hidden;
    border-radius: 9999px;
    background: color-mix(in oklch, var(--color-secondary) 60%, transparent);
  }

  .pagefind-search-progress__bar {
    height: 100%;
    border-radius: 9999px;
    transition: width 300ms ease;
  }

  .pagefind-search-progress__bar--indeterminate {
    width: 33.333%;
    background: var(--color-brand-500);
    animation: pagefind-progress-indeterminate 1.5s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  @keyframes pagefind-progress-indeterminate {
    0% {
      transform: translateX(-100%);
    }
    100% {
      transform: translateX(400%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pagefind-modal-overlay,
    .pagefind-modal {
      transition: none;
    }
    .pagefind-search-progress__bar--indeterminate {
      animation: none;
      width: 50%;
      transform: none;
    }
  }
</style>

<!-- Pagefind search JS (lazy-loaded on first interaction) -->
<script is:inline>
  (function () {
    var btn = document.getElementById('pagefind-search-btn');
    if (!btn) return;

    var controller = null;

    function initPagefindSearch(button) {
      if (controller) return controller;

      var searchLabel = button.dataset.searchLabel || 'Search';
      var searchModalTitle = button.dataset.searchModalTitle || 'Search the site';
      var searchPlaceholder = button.dataset.searchPlaceholder || 'Type a keyword...';

      var pagefindInstance = null;
      var pagefindLoaded = false;
      var pagefindLoading = false;
      var pagefindQueue = [];

      var overlay = document.createElement('div');
      overlay.className = 'pagefind-modal-overlay';
      overlay.innerHTML =
        '<div class="pagefind-modal">' +
        '<div class="pagefind-modal-header">' +
        '<h2 class="pagefind-modal-title">' + searchModalTitle + '</h2>' +
        '<button class="pagefind-modal-close" aria-label="' + searchLabel + '">' +
        '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
        '<path d="M18 6 6 18"/><path d="m6 6 12 12"/>' +
        '</svg>' +
        '</button>' +
        '</div>' +
        '<div id="pagefind-search-ui"></div>' +
        '<div id="pagefind-search-progress" class="pagefind-search-progress">' +
        '  <div class="pagefind-search-progress__track">' +
        '    <div class="pagefind-search-progress__bar pagefind-search-progress__bar--indeterminate"></div>' +
        '  </div>' +
        '</div>' +
        '</div>';
      document.body.appendChild(overlay);

      var closeBtn = overlay.querySelector('.pagefind-modal-close');
      var searchUiContainer = overlay.querySelector('#pagefind-search-ui');
      var progressEl = overlay.querySelector('#pagefind-search-progress');

      function showProgress() {
        if (progressEl) progressEl.classList.add('pagefind-search-progress--active');
      }

      function hideProgress() {
        if (progressEl) progressEl.classList.remove('pagefind-search-progress--active');
      }

      function loadPagefind() {
        return new Promise(function (resolve, reject) {
          if (pagefindLoaded) {
            resolve(pagefindInstance);
            return;
          }

          if (pagefindLoading) {
            pagefindQueue.push(function () {
              if (pagefindInstance) {
                resolve(pagefindInstance);
              } else {
                reject(new Error('Pagefind failed to load'));
              }
            });
            return;
          }

          pagefindLoading = true;

          import('/pagefind/pagefind.js')
            .then(async function (pf) {
              if (pf && typeof pf.init === 'function') {
                await pf.init();
              }

              pagefindLoaded = true;
              pagefindLoading = false;
              var queue = pagefindQueue.splice(0, pagefindQueue.length);
              pagefindInstance = pf;
              resolve(pf);
              queue.forEach(function (cb) {
                cb();
              });
            })
            .catch(function (err) {
              pagefindLoading = false;
              reject(new Error('Failed to load /pagefind/pagefind.js: ' + err.message));
              pagefindQueue.splice(0, pagefindQueue.length).forEach(function (cb) {
                cb();
              });
            });
        });
      }

      function closeSearch() {
        overlay.classList.remove('open');
        document.body.style.overflow = '';
      }

      function openSearch() {
        overlay.classList.add('open');
        document.body.style.overflow = 'hidden';

        var currentLang = document.documentElement.lang || 'en';

        showProgress();

        setTimeout(function () {
          (async function () {
            try {
              if (!pagefindInstance) {
                var pf = await loadPagefind();

                hideProgress();

                if (searchUiContainer) {
                  searchUiContainer.innerHTML =
                    '<div class="pagefind-ui">' +
                    '<div class="pagefind-ui__search-bar">' +
                    '<div class="pagefind-ui__search-input-wrapper">' +
                    '<svg class="pagefind-ui__search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
                    '<circle cx="11" cy="11" r="8"/>' +
                    '<path d="m21 21-4.3-4.3"/>' +
                    '</svg>' +
                    '<input class="pagefind-ui__search-input" type="text" placeholder="' + searchPlaceholder + '" />' +
                    '<kbd class="pagefind-ui__search-kbd">Ctrl+K</kbd>' +
                    '</div>' +
                    '</div>' +
                    '<div class="pagefind-ui__results"></div>' +
                    '</div>';
                }

                var input = searchUiContainer ? searchUiContainer.querySelector('.pagefind-ui__search-input') : null;
                var resultsContainer = searchUiContainer ? searchUiContainer.querySelector('.pagefind-ui__results') : null;

                var debounceTimer;
                if (input) {
                  input.addEventListener('input', function () {
                    if (debounceTimer) clearTimeout(debounceTimer);
                    var term = input.value.trim();
                    if (term.length < 2) {
                      if (resultsContainer) resultsContainer.innerHTML = '';
                      return;
                    }

                    debounceTimer = setTimeout(function () {
                      (async function () {
                        showProgress();
                        try {
                          var search = await pf.search(term, {
                            filters: { lang: [currentLang] },
                          });

                          hideProgress();

                          if (!search.results || search.results.length === 0) {
                            if (resultsContainer) {
                              resultsContainer.innerHTML = '<p class="pagefind-ui__message">' + (currentLang === 'ru' ? 'Ничего не найдено' : 'No results found') + '</p>';
                            }
                            return;
                          }

                          var html = '';
                          var count = 0;
                          for (var i = 0; i < search.results.length; i++) {
                            if (count >= 5) break;
                            var result = search.results[i];
                            var data = await result.data();
                            var url = data.url || '';
                            count++;
                            html +=


                              '<a href="' + url + '" class="pagefind-ui__result">' +
                              '<span class="pagefind-ui__result-title">' + (data.title || data.meta?.title || '') + '</span>' +
                              '<p class="pagefind-ui__result-excerpt">' + (data.excerpt || '') + '</p>' +

                              '</a>';
                          }
                          html += '<p class="pagefind-ui__message">' + count + ' ' + (currentLang === 'ru' ? 'результатов' : 'results') + '</p>';
                          if (resultsContainer) resultsContainer.innerHTML = html;
                        } catch (error) {
                          hideProgress();
                          console.warn('Pagefind search failed:', error);
                        }
                      })();
                    }, 300);
                  });
                }
              }
            } catch (error) {
              console.warn('Pagefind init failed:', error);
            }

            setTimeout(function () {
              var input = overlay.querySelector('.pagefind-ui__search-input');
              if (input) input.focus();
            }, 100);
          })();
        }, 50);
      }

      if (closeBtn) closeBtn.addEventListener('click', closeSearch);
      overlay.addEventListener('click', function (e) {
        if (e.target === overlay) closeSearch();
      });

      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && overlay.classList.contains('open')) {
          closeSearch();
        }
      });

      controller = {
        openSearch: openSearch,
        closeSearch: closeSearch,
      };

      return controller;
    }

    btn.addEventListener('click', function (e) {
      e.preventDefault();
      var searchController = initPagefindSearch(btn);
      searchController.openSearch();
    });

    document.addEventListener('keydown', function (e) {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        var searchController = initPagefindSearch(btn);
        searchController.openSearch();
      }
    });
  })();
</script>
