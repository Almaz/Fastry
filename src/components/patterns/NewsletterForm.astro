---
import Input from '@/components/ui/form/Input/Input.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { cn } from '@/lib/cn';

interface Props {
  action?: string;
  placeholder?: string;
  buttonText?: string;
  successMessage?: string;
  locale?: 'en' | 'ru';
  class?: string;
}

const {
  action = '/api/newsletter',
  placeholder = 'Enter your email',
  buttonText = 'Subscribe',
  successMessage = 'Thanks for subscribing!',
  locale = 'en',
  class: className,
} = Astro.props;

const labels: Record<string, Record<string, string>> = {
  en: {
    placeholder: 'Enter your email',
    buttonText: 'Subscribe',
    successMessage: 'Thanks for subscribing!',
    subscribingText: 'Subscribing...',
    errorGeneric: 'Something went wrong',
    errorNetwork: 'Subscription failed. Please try again.',
  },
  ru: {
    placeholder: 'Введите ваш email',
    buttonText: 'Подписаться',
    successMessage: 'Спасибо за подписку!',
    subscribingText: 'Подписка…',
    errorGeneric: 'Что-то пошло не так',
    errorNetwork: 'Не удалось подписаться. Пожалуйста, попробуйте снова.',
  },
};

const l = labels[locale] ?? labels.en;
const resolvedPlaceholder = placeholder === 'Enter your email' ? l.placeholder : placeholder;
const resolvedButtonText = buttonText === 'Subscribe' ? l.buttonText : buttonText;
const resolvedSuccessMessage = successMessage === 'Thanks for subscribing!' ? l.successMessage : successMessage;

<div>
  <form
    class={cn('newsletter-form', className)}
    action={action}
    method="POST"
    data-success-message={resolvedSuccessMessage}
    data-locale={locale}
  >
    <div class="flex flex-col sm:flex-row gap-3">
      <div class="flex-1">
        <Input
          name="email"
          type="email"

          placeholder={resolvedPlaceholder}
          required
          autocomplete="email"
        />
      </div>
      <Button type="submit" class="newsletter-submit">

        {resolvedButtonText}
      </Button>
    </div>
    <p class="newsletter-message hidden mt-3 text-sm"></p>
  </form>

  <script src="./newsletter-form.ts"></script>
</div>
